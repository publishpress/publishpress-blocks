# Docker container name
CONTAINER_NAME="publishpress-blocks"

# Docker image name
TERMINAL_IMAGE_NAME="publishpress/dev-workspace-terminal:publishpress-blocks"

# Path to the cache directory for the dev-workspace
CACHE_PATH="./.cache"

# The slug of the plugin to be tested.
PLUGIN_SLUG="advanced-gutenberg"

# The domain of the plugin to be tested.
LANG_DOMAIN="advanced-gutenberg"

# The directory of the language files.
LANG_DIR="languages"

# Script handles to generate per-locale translation JSON files for (space-separated)
SCRIPT_HANDLES="editor advgb_blocks advgb_pro_ad_js advgb_settings_js advgb_block_usage advgbNewsletter_js advgb_preset_data_manager advgb-preset-manager advgb_block_controls"

# Supported locales for translations (space-separated)
LANG_LOCALES="de_DE es_ES fi fil fr_FR id_ID it_IT ja ko_KR nl_NL pt_BR ru_RU yor"

# OpenAI API key for AI-assisted translation.
OPENAI_API_KEY=""

# Weblate API token for upload/download.
WEBLATE_API_TOKEN=""

# Optional Weblate API base URL.
WEBLATE_API_URL="https://weblate.publishpress.com/api/"

# Optional list of skipped languages (comma-separated).
SKIP_LANGUAGES="it_IT,es_ES,fr_FR,pt_BR"
